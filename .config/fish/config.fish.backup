#! /bin/sh
set fish_greeting
export EDITOR=nvim || export EDITOR=vim
source $HOME/.config/fish/shortcuts.fish
source $HOME/.config/fish/colors.fish
set -gx PATH $HOME/.local/bin /usr/local/bin $PATH
set fish_color_valid_path --bold

alias vi=$EDITOR
alias la='ls -lha'
alias df='df -h'
alias du='du -ch'
